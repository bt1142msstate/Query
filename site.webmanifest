{
  "name": "Library Item Reports",
  "short_name": "Item Reports",
  "description": "A responsive query builder and reporting tool for library item data.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#0f172a",
