{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bt1142msstate.github.io/Query/docs/schemas/query-api.schema.json",
  "title": "Item Query API Contract",
  "description": "Backend contract for the Item Query Project frontend. The recommended integration uses get_fields and run first, then adds history, cancellation, result loading, and templates as needed.",
  "$defs": {
    "scalar": {
      "type": ["string", "number", "integer", "boolean", "null"]
    },
    "cellValue": {
      "oneOf": [
        { "$ref": "#/$defs/scalar" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/scalar" }
        },
        {
          "type": "object",
          "properties": {
            "value": { "$ref": "#/$defs/cellValue" },
            "values": {
              "type": "array",
              "items": { "$ref": "#/$defs/cellValue" }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "fieldDefinition": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical field name sent back in display_fields and filters."
        },
        "label": {
          "type": "string",
          "description": "Optional user-facing label. Defaults to name."
        },
        "desc": {
          "type": "string",
          "description": "Optional user-facing field description."
        },
        "description": {
          "type": "string",
          "description": "Alias for desc."
        },
        "category": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "type": {
          "type": "string",
          "examples": ["string", "date", "number", "money", "boolean"]
        },
        "filters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "operators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "values": {
          "type": "array",
          "items": { "$ref": "#/$defs/scalar" }
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowValueList": { "type": "boolean" },
        "multiSelect": { "type": "boolean" },
        "groupValues": { "type": "boolean" },
        "sensitive": {
          "type": "boolean",
          "description": "Marks a field as sensitive or staff-only. This is a UI hint only; backend authorization must still enforce access."
        },
        "requiresAuth": {
          "type": "boolean",
          "description": "Marks a field as requiring an authenticated backend session."
        },
        "authRequired": {
          "type": "boolean",
          "description": "Alias for requiresAuth."
        },
        "authorized": {
          "type": "boolean",
          "description": "If false, the frontend disables display/filter actions for this field until the backend reports access."
        },
        "requiredScopes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional backend-defined roles/scopes/groups required for this field."
        },
        "authMessage": {
          "type": "string",
          "description": "Optional user-facing explanation when access is denied or sign-in is needed."
        },
        "accessMessage": {
          "type": "string",
          "description": "Alias for authMessage."
        },
        "access": {
          "oneOf": [
            { "type": "string" },
            { "type": "object", "additionalProperties": true }
          ],
          "description": "Optional structured access metadata. Common string values are restricted, protected, sensitive, denied, or unauthorized."
        },
        "parts": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional backend-specific hint when one displayed field is assembled from multiple backend values."
        },
        "numberFormat": { "type": "string" },
        "numericFormat": { "type": "string" },
        "warning": { "$ref": "#/$defs/fieldWarning" },
        "warnings": {
          "oneOf": [
            { "$ref": "#/$defs/fieldWarning" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/fieldWarning" }
            }
          ]
        },
        "builder": { "$ref": "#/$defs/fieldBuilder" }
      },
      "additionalProperties": true
    },
    "fieldWarning": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "message": { "type": "string" },
            "text": { "type": "string" },
            "detail": { "type": "string" },
            "description": { "type": "string" },
            "level": { "type": "string" },
            "severity": { "type": "string" },
            "type": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "fieldBuilder": {
      "type": "object",
      "required": ["outputFieldIdTemplate", "inputs"],
      "properties": {
        "outputFieldIdTemplate": {
          "type": "string",
          "description": "Template used to create the backend field id, for example Custom {code}${subfield}."
        },
        "displayLabelTemplate": {
          "type": "string",
          "description": "Optional template used for the user-facing label."
        },
        "matchPattern": {
          "type": "string",
          "description": "Regular expression string that matches generated field names when restoring saved queries."
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/builderInput" }
        }
      },
      "additionalProperties": true
    },
    "builderInput": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "examples": ["text", "select", "number"]
        },
        "pattern": {
          "type": "string",
          "description": "Optional regular expression string for client-side validation."
        },
        "placeholder": { "type": "string" },
        "optional": { "type": "boolean" },
        "error_msg": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/scalar" },
              {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "value": { "$ref": "#/$defs/scalar" }
                },
                "additionalProperties": true
              }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "backendFilter": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "enum": ["=", "!=", ">", "<", ">=", "<="]
        },
        "value": {
          "oneOf": [
            { "$ref": "#/$defs/scalar" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/scalar" }
            }
          ],
          "description": "Date filters use YYYYMMDD or NEVER. Text contains/starts filters may use backend wildcards such as *value* or value*."
        }
      },
      "additionalProperties": true
    },
    "getFieldsRequest": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "const": "get_fields" }
      },
      "additionalProperties": true
    },
    "getFieldsResponse": {
      "oneOf": [
        {
          "type": "object",
          "required": ["fields"],
          "properties": {
            "fields": {
              "type": "array",
              "items": { "$ref": "#/$defs/fieldDefinition" }
            }
          },
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/fieldDefinition" }
        }
      ]
    },
    "runRequest": {
      "type": "object",
      "required": ["action", "display_fields", "filters"],
      "properties": {
        "action": { "const": "run" },
        "name": { "type": "string" },
        "result_format": {
          "type": "string",
          "const": "jsonl",
          "description": "Canonical result response format. Query results stream as JSON Lines with meta, row, progress, done, warning, and error events."
        },
        "display_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/backendFilter" }
        }
      },
      "additionalProperties": true
    },
    "columnDescriptor": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "label": { "type": "string" },
            "fieldName": { "type": "string" },
            "field": { "type": "string" },
            "id": { "type": "string" },
            "key": { "type": "string" },
            "source": { "type": "string" },
            "sourceName": { "type": "string" },
            "output": { "type": "string" },
            "column": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "resultRow": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/cellValue" }
        },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/cellValue" }
        }
      ]
    },
    "jsonlProtocolVersion": {
      "type": "integer",
      "const": 1,
      "description": "Current streaming JSONL protocol version. Backends must emit this on the meta event so clients can fail fast on incompatible streams."
    },
    "jsonlMetaEvent": {
      "type": "object",
      "required": ["type", "version", "format", "columns"],
      "properties": {
        "type": { "const": "meta" },
        "version": { "$ref": "#/$defs/jsonlProtocolVersion" },
        "format": { "const": "jsonl" },
        "query_id": { "type": "string" },
        "queryId": { "type": "string" },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/columnDescriptor" }
        },
        "headers": {
          "type": "array",
          "items": { "$ref": "#/$defs/columnDescriptor" }
        }
      },
      "additionalProperties": true
    },
    "jsonlRowEvent": {
      "type": "object",
      "required": ["type", "values"],
      "properties": {
        "type": { "const": "row" },
        "values": {
          "type": "array",
          "items": { "$ref": "#/$defs/cellValue" },
          "description": "Ordered row values matching the meta.columns order. Array cell values represent multi-value fields."
        }
      },
      "additionalProperties": true
    },
    "jsonlProgressEvent": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "progress" },
        "rows": { "type": "integer", "minimum": 0 },
        "row_count": { "type": "integer", "minimum": 0 },
        "rowCount": { "type": "integer", "minimum": 0 },
        "message": { "type": "string" },
        "progress": { "$ref": "#/$defs/progress" }
      },
      "additionalProperties": true
    },
    "jsonlWarningEvent": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "warning" },
        "message": { "type": "string" },
        "warning": { "type": "string" },
        "stage": { "type": "string" },
        "error_details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "jsonlErrorEvent": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "const": "error" },
        "error": { "type": "string" },
        "message": { "type": "string" },
        "stage": { "type": "string" },
        "error_details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "anyOf": [
        { "required": ["error"] },
        { "required": ["message"] }
      ],
      "additionalProperties": true
    },
    "jsonlDoneEvent": {
      "type": "object",
      "required": ["type", "rows"],
      "properties": {
        "type": { "const": "done" },
        "rows": { "type": "integer", "minimum": 0 },
        "elapsed_ms": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "jsonlEvent": {
      "oneOf": [
        { "$ref": "#/$defs/jsonlMetaEvent" },
        { "$ref": "#/$defs/jsonlRowEvent" },
        { "$ref": "#/$defs/jsonlProgressEvent" },
        { "$ref": "#/$defs/jsonlWarningEvent" },
        { "$ref": "#/$defs/jsonlErrorEvent" },
        { "$ref": "#/$defs/jsonlDoneEvent" }
      ]
    },
    "queryResult": {
      "type": "object",
      "required": ["columns", "rows"],
      "properties": {
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/columnDescriptor" }
        },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/resultRow" }
        },
        "query_id": { "type": "string" },
        "progress": { "$ref": "#/$defs/progress" }
      },
      "additionalProperties": true
    },
    "statusRequest": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "const": "status" }
      },
      "additionalProperties": true
    },
    "statusResponse": {
      "type": "object",
      "properties": {
        "queries": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/queryStatus" }
            },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/queryStatus" }
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "queryStatus": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "query_id": { "type": "string" },
        "name": { "type": "string" },
        "status": {
          "type": "string",
          "examples": ["running", "complete", "failed", "canceled"]
        },
        "start_time": { "type": "string" },
        "end_time": { "type": "string" },
        "row_count": { "type": "integer", "minimum": 0 },
        "result_count": { "type": "integer", "minimum": 0 },
        "progress": { "$ref": "#/$defs/progress" },
        "request": { "$ref": "#/$defs/runRequest" },
        "ui_config": { "$ref": "#/$defs/uiConfig" },
        "error": { "type": "string" },
        "error_details": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "progress": {
      "type": "object",
      "properties": {
        "schema_version": { "type": "integer", "minimum": 1 },
        "stage": { "type": "string" },
        "label": { "type": "string" },
        "detail": { "type": "string" },
        "current": { "type": "number" },
        "total": { "type": "number" },
        "percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "unit": { "type": "string" },
        "counters": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": true
    },
    "uiConfig": {
      "type": "object",
      "properties": {
        "DesiredColumnOrder": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiConfigFilter" }
        }
      },
      "additionalProperties": true
    },
    "uiConfigFilter": {
      "type": "object",
      "properties": {
        "FieldName": { "type": "string" },
        "FieldOperator": { "type": "string" },
        "Values": {
          "type": "array",
          "items": { "$ref": "#/$defs/scalar" }
        }
      },
      "additionalProperties": true
    },
    "cancelRequest": {
      "type": "object",
      "required": ["action", "query_id"],
      "properties": {
        "action": { "const": "cancel" },
        "query_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "getResultsRequest": {
      "type": "object",
      "required": ["action", "query_id"],
      "properties": {
        "action": { "const": "get_results" },
        "query_id": { "type": "string", "minLength": 1 },
        "result_format": {
          "type": "string",
          "const": "jsonl",
          "description": "Canonical saved-result response format. Saved results stream as JSON Lines events."
        }
      },
      "additionalProperties": true
    },
    "errorResponse": {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": { "type": "string" },
        "error_details": {
          "type": "object",
          "additionalProperties": true
        },
        "errorDetails": {
          "type": "object",
          "additionalProperties": true
        },
        "retry_after_seconds": { "type": "number", "minimum": 0 },
        "retry_after": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string" }
          ]
        }
      },
      "additionalProperties": true
    },
    "template": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "svg": { "type": "string" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "ui_config": { "$ref": "#/$defs/uiConfig" },
        "pinned": { "type": "boolean" },
        "pin_order": { "type": "number" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "anyOf": [
    { "$ref": "#/$defs/getFieldsRequest" },
    { "$ref": "#/$defs/getFieldsResponse" },
    { "$ref": "#/$defs/runRequest" },
    { "$ref": "#/$defs/queryResult" },
    { "$ref": "#/$defs/jsonlEvent" },
    { "$ref": "#/$defs/statusRequest" },
    { "$ref": "#/$defs/statusResponse" },
    { "$ref": "#/$defs/cancelRequest" },
    { "$ref": "#/$defs/getResultsRequest" },
    { "$ref": "#/$defs/errorResponse" },
    { "$ref": "#/$defs/template" }
  ]
}
